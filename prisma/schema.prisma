generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  WEBSITE_OWNER
  MEMBER
  APPLICANT
}

enum SciolyDivision {
  B
  C
  OTHER
}

enum MembershipStatus {
  PENDING
  ACTIVE
  INACTIVE
  ALUMNI
  REMOVED
}

enum MembershipApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  WAITLISTED
  DENIED
  WITHDRAWN
}

enum EventEnrollmentStatus {
  INTERESTED
  TRYOUT_PENDING
  ACTIVE
  WAITLISTED
  DROPPED
}

enum CompetitionType {
  PRACTICE
  INVITATIONAL
  REGIONAL
  STATE
  NATIONAL
  OTHER
}

enum RosterMemberRole {
  MEMBER
  CAPTAIN
  ALTERNATE
}

enum CompetitionEntryStatus {
  PLANNED
  CONFIRMED
  FINALIZED
  DROPPED
}

enum FormCategory {
  WAIVER
  MEDICAL
  PERMISSION
  CODE_OF_CONDUCT
  TRAVEL
  PHOTO_RELEASE
  CLUB_CONTRACT
  OTHER
}

enum FormSubmissionStatus {
  NOT_STARTED
  SUBMITTED
  VERIFIED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  VOID
  OVERDUE
}

enum PaymentMethod {
  CASH
  CHECK
  CARD
  ZELLE
  VENMO
  PAYPAL
  OTHER
}

enum HourEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum HourEvidencePolicy {
  NONE
  OPTIONAL
  REQUIRED
}

enum ResourceType {
  LINK
  FILE
  DOC
  VIDEO
  SHEET
  FOLDER
  OTHER
}

enum ClubEventType {
  MEETING
  SUPER_SATURDAY
  FUNDRAISER
  WORKSHOP
  FIELD_TRIP
  OTHER
}

enum FinanceAccountType {
  CHECKING
  CASH
  SAVINGS
  FUNDRAISER
  RESTRICTED
  OTHER
}

enum FinanceEntryDirection {
  CREDIT
  DEBIT
}

enum FinanceEntryCategory {
  DUES
  DONATION
  FUNDRAISER
  REGISTRATION
  TRAVEL
  SNACKS
  SUPPLIES
  REIMBURSEMENT
  AWARD
  OTHER
}

enum AssessmentFormat {
  TEST
  STATIONS
  HYBRID
  GENERATED
}

enum AssessmentDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AssessmentAssetKind {
  QUESTION_PDF
  ANSWER_KEY_PDF
  SOURCE_PDF
  REFERENCE_IMAGE
  SUPPLEMENTAL_FILE
  EXTERNAL_LINK
  RUBRIC
  OTHER
}

enum AssessmentPartType {
  SECTION
  STATION
}

enum AssessmentResponseType {
  MULTIPLE_CHOICE
  SHORT_TEXT
  LONG_TEXT
  NUMERIC
  BOOLEAN
  FILE_UPLOAD
  OTHER
}

enum AssessmentAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  SCORED
  ABANDONED
}

// ─── Core ─────────────────────────────────────────────────────────────────────

model Club {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  schoolName   String?
  schoolDomain String?
  description  String?
  division     SciolyDivision?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  users           User[]
  seasons         Season[]
  roles           ClubRole[]
  activityLogs    ActivityLog[]
  emailDomains    ClubEmailDomain[]
  applications    MembershipApplication[]
  financeAccounts FinanceAccount[]
  financeEntries  FinanceEntry[]
  assets          Asset[]
}

model ClubEmailDomain {
  id        String   @id @default(cuid())
  clubId    String
  domain    String
  label     String?
  isPrimary Boolean  @default(false)
  isStudentDomain Boolean @default(true)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, domain])
  @@index([clubId, isActive])
}

model Season {
  id         String          @id @default(cuid())
  clubId     String
  name       String
  schoolYear String
  division   SciolyDivision?
  startsAt   DateTime
  endsAt     DateTime
  isActive   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  club               Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members            MemberSeason[]
  events             Event[]
  competitions       Competition[]
  formTypes          FormType[]
  invoices           DuesInvoice[]
  hourPrograms       HourProgram[]
  hourCategories     HourCategory[]
  clubEvents         ClubEvent[]
  resources          Resource[]
  announcements      Announcement[]
  applications       MembershipApplication[]
  rosters            SeasonRoster[]
  competitionRosters CompetitionRoster[]
  assessments        Assessment[]
  financeAccounts    FinanceAccount[]
  financeEntries     FinanceEntry[]
  assets             Asset[]

  @@unique([clubId, schoolYear])
  @@index([clubId, isActive])
}

model User {
  id              String      @id @default(cuid())
  clubId          String
  email           String      @unique
  passwordHash    String?
  role            UserRole    @default(MEMBER)
  firstName       String
  lastName        String
  displayName     String?
  gradeLevel      Int?
  graduationYear  Int?
  studentNumber   String?
  phone           String?
  imageUrl        String?
  emailVerifiedAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  club                   Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  seasonMemberships      MemberSeason[]
  verifiedForms          FormSubmission[]        @relation("VerifiedForms")
  recordedPayments       PaymentRecord[]         @relation("RecordedPayments")
  approvedHours          HourEntry[]             @relation("ApprovedHours")
  uploadedResources      Resource[]              @relation("UploadedResources")
  createdAnnouncements   Announcement[]          @relation("AnnouncementCreator")
  activityLogs           ActivityLog[]           @relation("ActivityActor")
  passwordSetupTokens    PasswordSetupToken[]
  submittedApplications  MembershipApplication[] @relation("ApplicantUser")
  reviewedApplications   MembershipApplication[] @relation("ApplicationReviewer")
  uploadedAssets         Asset[]                 @relation("UploadedAssets")
  recordedFinanceEntries FinanceEntry[]          @relation("FinanceRecorder")
  recordedResults        CompetitionEventAssignment[] @relation("RecordedCompetitionResults")

  @@index([clubId, role])
  @@index([lastName, firstName])
}

model PasswordSetupToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MembershipApplication {
  id                String                      @id @default(cuid())
  clubId            String
  seasonId          String
  userId            String?
  memberSeasonId    String?                     @unique
  reviewedById      String?
  firstName         String
  lastName          String
  email             String
  phone             String?
  gradeLevel        Int?
  graduationYear    Int?
  shirtSize         String?
  isReturning       Boolean                     @default(false)
  canTravel         Boolean                     @default(false)
  whyJoin           String?
  contributionIdeas String?
  awards            String?
  previousEvents    String?
  scienceClasses    String?
  mathClasses       String?
  questions         String?
  focusPageFileUrl  String?
  status            MembershipApplicationStatus @default(SUBMITTED)
  answers           Json?
  submittedAt       DateTime                    @default(now())
  reviewedAt        DateTime?
  decisionReason    String?
  decisionNotes     String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  club          Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season        Season                   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user          User?                    @relation("ApplicantUser", fields: [userId], references: [id], onDelete: SetNull)
  memberSeason  MemberSeason?            @relation(fields: [memberSeasonId], references: [id], onDelete: SetNull)
  reviewedBy    User?                    @relation("ApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  eventChoices  ApplicationEventChoice[]

  @@unique([seasonId, email])
  @@index([clubId, status])
  @@index([seasonId, status])
  @@index([userId])
  @@index([memberSeasonId])
  @@index([reviewedById])
}

model ApplicationEventChoice {
  id             String @id @default(cuid())
  applicationId  String
  eventId        String
  preferenceRank Int

  application MembershipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  event       Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([applicationId, eventId])
  @@unique([applicationId, preferenceRank])
  @@index([eventId])
}

model MemberSeason {
  id               String           @id @default(cuid())
  userId           String
  seasonId         String
  membershipStatus MembershipStatus @default(PENDING)
  joinedAt         DateTime         @default(now())
  isReturning      Boolean          @default(false)
  canTravel        Boolean          @default(false)
  shirtSize        String?
  notes            String?

  whyJoin                String?
  contributionIdeas      String?
  awards                 String?
  previousEvents         String?
  scienceClasses         String?
  mathClasses            String?
  questions              String?
  focusPageFileUrl       String?
  applicationSubmittedAt DateTime?
  statusChangedAt        DateTime?
  statusReason           String?

  expectedHours Decimal? @db.Decimal(5, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user                       User                               @relation(fields: [userId], references: [id], onDelete: Cascade)
  season                     Season                             @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  eventEnrollments           EventEnrollment[]
  rosterMemberships          SeasonRosterMember[]
  competitionAssignmentSlots CompetitionAssignmentParticipant[]
  formSubmissions            FormSubmission[]
  invoices                   DuesInvoice[]
  payments                   PaymentRecord[]
  financeEntries             FinanceEntry[]
  hourEntries                HourEntry[]
  eventAttendances           ClubEventAttendance[]
  assessmentAttempts         AssessmentAttempt[]
  roles                      MemberRole[]
  application                MembershipApplication?

  @@unique([userId, seasonId])
  @@index([seasonId, membershipStatus])
}

// ─── Roles ────────────────────────────────────────────────────────────────────

// ClubRole is club-scoped (not season-scoped). Members are assigned roles per MemberSeason.
// permissions is a flat JSON object: { "view_members": true, "edit_members": false, ... }
model ClubRole {
  id          String   @id @default(cuid())
  clubId      String
  name        String
  description String?
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club    Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members MemberRole[]

  @@unique([clubId, name])
  @@index([clubId])
}

model MemberRole {
  id             String   @id @default(cuid())
  memberSeasonId String
  clubRoleId     String
  assignedAt     DateTime @default(now())

  memberSeason MemberSeason @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)
  clubRole     ClubRole     @relation(fields: [clubRoleId], references: [id], onDelete: Cascade)

  @@unique([memberSeasonId, clubRoleId])
  @@index([memberSeasonId])
  @@index([clubRoleId])
}

// ─── Events & Competitions ────────────────────────────────────────────────────

model Event {
  id              String   @id @default(cuid())
  seasonId        String
  code            String?
  name            String
  description     String?
  minParticipants Int      @default(2)
  maxParticipants Int      @default(2)
  isTrialEvent    Boolean  @default(false)
  sortOrder       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  season                 Season                       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  applicationChoices     ApplicationEventChoice[]
  enrollments            EventEnrollment[]
  eventSchedules         EventSchedule[]
  eventSlots             CompetitionEventSlot[]
  competitionAssignments CompetitionEventAssignment[]
  resources              Resource[]
  announcements          Announcement[]
  assessments            Assessment[]

  @@unique([seasonId, name])
  @@index([seasonId, sortOrder])
}

model Competition {
  id          String          @id @default(cuid())
  seasonId    String
  name        String
  type        CompetitionType @default(OTHER)
  division    SciolyDivision?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  isPublished Boolean         @default(false)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  season         Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  rosters        CompetitionRoster[]
  eventSchedules EventSchedule[]
  eventSlots     CompetitionEventSlot[]
  resources      Resource[]
  announcements  Announcement[]

  @@unique([seasonId, name])
  @@index([seasonId, type])
}

model EventSchedule {
  id            String  @id @default(cuid())
  competitionId String
  eventId       String
  timeSlot      Int
  slotLabel     String?
  room          String?
  startsAt      DateTime?
  endsAt        DateTime?
  notes         String?

  competition Competition                  @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  event       Event                        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventSlot   CompetitionEventSlot?
  assignments CompetitionEventAssignment[]

  @@unique([competitionId, eventId])
  @@index([competitionId])
}

model SeasonRoster {
  id          String          @id @default(cuid())
  seasonId    String
  name        String
  division    SciolyDivision?
  memberLimit Int?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  season             Season               @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  members            SeasonRosterMember[]
  competitionRosters CompetitionRoster[]
  resources          Resource[]
  announcements      Announcement[]

  @@unique([seasonId, name])
  @@index([seasonId, division])
}

model SeasonRosterMember {
  id             String         @id @default(cuid())
  rosterId       String
  memberSeasonId String
  role           RosterMemberRole @default(MEMBER)
  assignedAt     DateTime       @default(now())
  notes          String?

  roster       SeasonRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  memberSeason MemberSeason @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)

  @@unique([rosterId, memberSeasonId])
  @@index([rosterId, role])
  @@index([memberSeasonId])
}

model CompetitionRoster {
  id             String          @id @default(cuid())
  seasonId       String
  competitionId  String
  seasonRosterId String?
  label          String
  division       SciolyDivision?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  season       Season                       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  competition  Competition                  @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  seasonRoster SeasonRoster?                @relation(fields: [seasonRosterId], references: [id], onDelete: SetNull)
  assignments  CompetitionEventAssignment[]
  resources    Resource[]
  announcements Announcement[]

  @@unique([competitionId, label])
  @@index([seasonId])
  @@index([competitionId])
  @@index([seasonRosterId])
}

model CompetitionEventSlot {
  id            String   @id @default(cuid())
  competitionId String
  eventId       String?
  scheduleId    String?  @unique
  label         String
  room          String?
  startsAt      DateTime?
  endsAt        DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  competition Competition                  @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  event       Event?                       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  schedule    EventSchedule?               @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  assignments CompetitionEventAssignment[]

  @@index([competitionId])
  @@index([competitionId, eventId])
}

model CompetitionEventAssignment {
  id                  String   @id @default(cuid())
  competitionRosterId String
  eventId             String
  scheduleId          String?
  slotId              String?
  entryLabel          String?
  status              CompetitionEntryStatus @default(PLANNED)
  room                String?
  block               String?
  notes               String?
  // Results (recorded after the event runs)
  placement           Int?
  scoreEarned         Decimal? @db.Decimal(8, 2)
  scorePossible       Decimal? @db.Decimal(8, 2)
  medalNotes          String?
  resultRecordedAt    DateTime?
  resultRecordedById  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  competitionRoster CompetitionRoster                  @relation(fields: [competitionRosterId], references: [id], onDelete: Cascade)
  event             Event                              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  schedule          EventSchedule?                     @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  slot              CompetitionEventSlot?             @relation(fields: [slotId], references: [id], onDelete: SetNull)
  resultRecordedBy  User?                              @relation("RecordedCompetitionResults", fields: [resultRecordedById], references: [id], onDelete: SetNull)
  participants      CompetitionAssignmentParticipant[]

  @@unique([competitionRosterId, eventId])
  @@index([competitionRosterId])
  @@index([eventId])
  @@index([scheduleId])
  @@index([slotId])
}

model CompetitionAssignmentParticipant {
  id                           String         @id @default(cuid())
  competitionEventAssignmentId String
  memberSeasonId               String
  role                         RosterMemberRole @default(MEMBER)
  seatNumber                   Int?
  assignedAt                   DateTime       @default(now())
  notes                        String?

  competitionEventAssignment CompetitionEventAssignment @relation(fields: [competitionEventAssignmentId], references: [id], onDelete: Cascade)
  memberSeason               MemberSeason               @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)

  @@unique([competitionEventAssignmentId, memberSeasonId])
  @@index([competitionEventAssignmentId, role])
  @@index([memberSeasonId])
}

model EventEnrollment {
  id             String                @id @default(cuid())
  memberSeasonId String
  eventId        String
  status         EventEnrollmentStatus @default(INTERESTED)
  preferenceRank Int?
  tryoutScore    Decimal?              @db.Decimal(6, 2)
  skillRating    Int?
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  memberSeason MemberSeason @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([memberSeasonId, eventId])
  @@index([eventId, status])
  @@index([memberSeasonId])
}

// ─── Hours ────────────────────────────────────────────────────────────────────

model HourProgram {
  id          String    @id @default(cuid())
  seasonId    String
  name        String
  code        String?
  description String?
  startsAt    DateTime?
  endsAt      DateTime?
  targetHours Decimal?  @db.Decimal(6, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  season     Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  categories HourCategory[]

  @@unique([seasonId, name])
  @@index([seasonId, isActive])
}

model HourCategory {
  id                String             @id @default(cuid())
  seasonId          String
  programId         String?
  name              String
  description       String?
  requiredHours     Decimal?           @db.Decimal(5, 2)
  requiresApproval  Boolean            @default(true)
  evidencePolicy    HourEvidencePolicy @default(OPTIONAL)
  maxHoursPerEntry  Decimal?           @db.Decimal(5, 2)
  proofInstructions String?
  sortOrder         Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  program     HourProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)
  hourEntries HourEntry[]
  clubEvents  ClubEvent[]

  @@unique([seasonId, name])
  @@index([seasonId])
  @@index([programId])
}

model HourEntry {
  id              String          @id @default(cuid())
  memberSeasonId  String
  categoryId      String
  title           String
  description     String?
  totalHours      Decimal         @db.Decimal(5, 2)
  proofUrl        String?
  proofAssetId    String?
  evidenceText    String?
  status          HourEntryStatus @default(PENDING)
  submittedAt     DateTime        @default(now())
  approvedAt      DateTime?
  approvedById    String?
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  memberSeason MemberSeason         @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)
  category     HourCategory         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  proofAsset   Asset?               @relation("HourProofAsset", fields: [proofAssetId], references: [id], onDelete: SetNull)
  approvedBy   User?                @relation("ApprovedHours", fields: [approvedById], references: [id], onDelete: SetNull)
  attendance   ClubEventAttendance?

  @@index([memberSeasonId, status])
  @@index([categoryId])
  @@index([proofAssetId])
  @@index([approvedById])
}

// ─── Club Events ──────────────────────────────────────────────────────────────

model ClubEvent {
  id         String        @id @default(cuid())
  seasonId   String
  name       String
  type       ClubEventType @default(OTHER)
  location   String?
  startsAt   DateTime
  endsAt     DateTime?
  hoursValue Decimal       @default(0) @db.Decimal(5, 2)
  categoryId String?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  season     Season                @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  category   HourCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  attendance ClubEventAttendance[]

  @@index([seasonId, startsAt])
}

model ClubEventAttendance {
  id             String   @id @default(cuid())
  clubEventId    String
  memberSeasonId String
  markedAt       DateTime @default(now())
  hourEntryId    String?  @unique

  clubEvent    ClubEvent    @relation(fields: [clubEventId], references: [id], onDelete: Cascade)
  memberSeason MemberSeason @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)
  hourEntry    HourEntry?   @relation(fields: [hourEntryId], references: [id], onDelete: SetNull)

  @@unique([clubEventId, memberSeasonId])
  @@index([memberSeasonId])
}

// ─── Finances ─────────────────────────────────────────────────────────────────

model DuesInvoice {
  id              String        @id @default(cuid())
  seasonId        String
  memberSeasonId  String
  title           String
  description     String?
  amountCents     Int
  amountPaidCents Int           @default(0)
  status          InvoiceStatus @default(OPEN)
  dueAt           DateTime?
  issuedAt        DateTime      @default(now())
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  season         Season          @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  memberSeason   MemberSeason    @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)
  payments       PaymentRecord[]
  financeEntries FinanceEntry[]

  @@index([seasonId, status])
  @@index([memberSeasonId, status])
}

model PaymentRecord {
  id              String        @id @default(cuid())
  invoiceId       String
  memberSeasonId  String
  amountCents     Int
  method          PaymentMethod @default(OTHER)
  referenceNumber String?
  receiptUrl      String?
  receiptAssetId  String?
  notes           String?
  paidAt          DateTime      @default(now())
  recordedById    String?
  createdAt       DateTime      @default(now())

  invoice        DuesInvoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  memberSeason   MemberSeason   @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)
  receiptAsset   Asset?         @relation("PaymentReceiptAsset", fields: [receiptAssetId], references: [id], onDelete: SetNull)
  recordedBy     User?          @relation("RecordedPayments", fields: [recordedById], references: [id], onDelete: SetNull)
  financeEntries FinanceEntry[]

  @@index([invoiceId])
  @@index([memberSeasonId])
  @@index([receiptAssetId])
  @@index([recordedById])
}

model FinanceAccount {
  id          String             @id @default(cuid())
  clubId      String
  seasonId    String?
  name        String
  type        FinanceAccountType @default(OTHER)
  description String?
  isDefault   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  club    Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season  Season?        @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  entries FinanceEntry[]

  @@unique([clubId, name])
  @@index([clubId, type])
  @@index([seasonId])
}

model FinanceEntry {
  id              String                @id @default(cuid())
  clubId          String
  seasonId        String?
  accountId       String?
  memberSeasonId  String?
  invoiceId       String?
  paymentRecordId String?
  recordedById    String?
  direction       FinanceEntryDirection
  category        FinanceEntryCategory  @default(OTHER)
  amountCents     Int
  title           String
  description     String?
  externalRef     String?
  occurredAt      DateTime              @default(now())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  club          Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season        Season?         @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  account       FinanceAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  memberSeason  MemberSeason?   @relation(fields: [memberSeasonId], references: [id], onDelete: SetNull)
  invoice       DuesInvoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentRecord PaymentRecord?  @relation(fields: [paymentRecordId], references: [id], onDelete: SetNull)
  recordedBy    User?           @relation("FinanceRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([clubId, occurredAt])
  @@index([seasonId])
  @@index([accountId])
  @@index([memberSeasonId])
  @@index([invoiceId])
  @@index([paymentRecordId])
  @@index([recordedById])
}

// ─── Forms ────────────────────────────────────────────────────────────────────

model FormType {
  id             String       @id @default(cuid())
  seasonId       String
  name           String
  category       FormCategory @default(OTHER)
  description    String?
  isRequired     Boolean      @default(true)
  requiresUpload Boolean      @default(false)
  dueAt          DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  season      Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@unique([seasonId, name])
  @@index([seasonId, category])
}

model FormSubmission {
  id              String               @id @default(cuid())
  formTypeId      String
  memberSeasonId  String
  status          FormSubmissionStatus @default(NOT_STARTED)
  acknowledgement Boolean              @default(false)
  fileUrl         String?
  fileAssetId     String?
  submittedAt     DateTime?
  verifiedAt      DateTime?
  verifiedById    String?
  rejectionReason String?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  formType     FormType     @relation(fields: [formTypeId], references: [id], onDelete: Cascade)
  memberSeason MemberSeason @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)
  fileAsset    Asset?       @relation("FormSubmissionAsset", fields: [fileAssetId], references: [id], onDelete: SetNull)
  verifiedBy   User?        @relation("VerifiedForms", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@unique([formTypeId, memberSeasonId])
  @@index([memberSeasonId, status])
  @@index([fileAssetId])
  @@index([verifiedById])
}

// ─── Assets, Resources & Announcements ───────────────────────────────────────

model Asset {
  id              String   @id @default(cuid())
  clubId          String
  seasonId        String?
  uploadedById    String?
  kind            String
  fileName        String
  storageProvider String?
  storageKey      String?
  publicUrl       String?
  mimeType        String?
  sizeBytes       Int?
  checksum        String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  club                 Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season               Season?           @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  uploadedBy           User?             @relation("UploadedAssets", fields: [uploadedById], references: [id], onDelete: SetNull)
  hourProofEntries     HourEntry[]       @relation("HourProofAsset")
  formSubmissionFiles  FormSubmission[]  @relation("FormSubmissionAsset")
  paymentReceiptFiles  PaymentRecord[]   @relation("PaymentReceiptAsset")
  assessmentAssets     AssessmentAsset[] @relation("AssessmentLinkedAsset")

  @@index([clubId, kind])
  @@index([seasonId])
  @@index([uploadedById])
}

model Resource {
  id            String       @id @default(cuid())
  seasonId      String
  eventId       String?
  competitionId String?
  seasonRosterId String?
  competitionRosterId String?
  title         String
  description   String?
  type          ResourceType @default(LINK)
  url           String
  uploadedById  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  event       Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  competition Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  seasonRoster SeasonRoster? @relation(fields: [seasonRosterId], references: [id], onDelete: SetNull)
  competitionRoster CompetitionRoster? @relation(fields: [competitionRosterId], references: [id], onDelete: SetNull)
  uploadedBy  User?        @relation("UploadedResources", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([seasonId])
  @@index([eventId])
  @@index([competitionId])
  @@index([seasonRosterId])
  @@index([competitionRosterId])
}

model Announcement {
  id            String    @id @default(cuid())
  seasonId      String
  eventId       String?
  competitionId String?
  seasonRosterId String?
  competitionRosterId String?
  title         String
  body          String
  isPinned      Boolean   @default(false)
  publishedAt   DateTime?
  expiresAt     DateTime?
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  event       Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  competition Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  seasonRoster SeasonRoster? @relation(fields: [seasonRosterId], references: [id], onDelete: SetNull)
  competitionRoster CompetitionRoster? @relation(fields: [competitionRosterId], references: [id], onDelete: SetNull)
  createdBy   User?        @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([seasonId, publishedAt])
  @@index([eventId])
  @@index([competitionId])
  @@index([seasonRosterId])
  @@index([competitionRosterId])
}

// ─── Assessments & Practice Tests ────────────────────────────────────────────

model Assessment {
  id               String           @id @default(cuid())
  seasonId         String
  eventId          String?
  title            String
  description      String?
  format           AssessmentFormat @default(TEST)
  instructions     String?
  timeLimitMinutes Int?
  isPublished      Boolean          @default(false)
  isArchived       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  season             Season              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  event              Event?              @relation(fields: [eventId], references: [id], onDelete: SetNull)
  assets             AssessmentAsset[]
  parts              AssessmentPart[]
  prompts            AssessmentPrompt[]
  attempts           AssessmentAttempt[]

  @@index([seasonId, isPublished])
  @@index([eventId])
}

model AssessmentAsset {
  id           String              @id @default(cuid())
  assessmentId String
  assetId      String?
  label        String
  kind         AssessmentAssetKind @default(QUESTION_PDF)
  externalUrl  String?
  pageFrom     Int?
  pageTo       Int?
  sortOrder    Int?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  asset      Asset?     @relation("AssessmentLinkedAsset", fields: [assetId], references: [id], onDelete: SetNull)

  @@index([assessmentId, sortOrder])
  @@index([assetId])
}

model AssessmentPart {
  id               String             @id @default(cuid())
  assessmentId     String
  title            String
  type             AssessmentPartType @default(SECTION)
  instructions     String?
  sortOrder        Int
  pageFrom         Int?
  pageTo           Int?
  timeLimitMinutes Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  prompts    AssessmentPrompt[]

  @@unique([assessmentId, sortOrder])
  @@index([assessmentId])
}

model AssessmentPrompt {
  id              String                 @id @default(cuid())
  assessmentId    String
  partId          String?
  promptNumber    Int
  label           String?
  responseType    AssessmentResponseType @default(SHORT_TEXT)
  pointsPossible  Decimal?               @db.Decimal(6, 2)
  answerKeyText   String?
  choiceOptions   Json?
  correctChoiceIndex Int?
  difficulty      AssessmentDifficulty?
  subtopics       String[]               @default([])
  pageRef         String?
  instructions    String?
  isRequired      Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  assessment Assessment           @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  part       AssessmentPart?      @relation(fields: [partId], references: [id], onDelete: SetNull)
  responses  AssessmentResponse[]

  @@unique([assessmentId, promptNumber])
  @@index([partId])
  @@index([difficulty])
}

model AssessmentAttempt {
  id                   String                  @id @default(cuid())
  assessmentId         String
  memberSeasonId       String
  status               AssessmentAttemptStatus @default(IN_PROGRESS)
  scoreEarned          Decimal?                @db.Decimal(6, 2)
  scorePossible        Decimal?                @db.Decimal(6, 2)
  startedAt            DateTime                @default(now())
  submittedAt          DateTime?
  gradedAt             DateTime?
  // For dynamically generated tests: which filter combination produced
  // this attempt? Lets us re-generate similar tests later.
  generatedFromFilters Json?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  assessment   Assessment           @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  memberSeason MemberSeason         @relation(fields: [memberSeasonId], references: [id], onDelete: Cascade)
  responses    AssessmentResponse[]

  @@index([assessmentId])
  @@index([memberSeasonId])
  @@index([status])
}

model AssessmentResponse {
  id            String   @id @default(cuid())
  attemptId     String
  promptId      String
  responseText  String?
  responseJson  Json?
  isCorrect     Boolean?
  pointsAwarded Decimal? @db.Decimal(6, 2)
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  attempt AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  prompt  AssessmentPrompt  @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, promptId])
  @@index([promptId])
}

model RateLimitBucket {
  key       String   @id
  count     Int
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  clubId     String
  actorId    String?
  entityType String
  entityId   String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  club  Club  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  actor User? @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([clubId, createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
}
